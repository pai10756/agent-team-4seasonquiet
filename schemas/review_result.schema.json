{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_result.schema.json",
  "title": "Review Result v3",
  "description": "reviewer 輸出的結構化審查結果。v3 新增 visual_brand_layer 美感與品牌一致性審查。",
  "type": "object",

  "required": ["verdict", "lock_layer", "guardrail_layer", "visual_brand_layer", "summary"],

  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "pass_with_notes"]
    },

    "attempt": {
      "type": "integer",
      "minimum": 1
    },

    "lock_layer": {
      "type": "object",
      "required": ["passed", "violations"],
      "description": "鎖死層 — 任一違規 = fail",
      "properties": {
        "passed": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/violation" }
        }
      }
    },

    "visual_brand_layer": {
      "type": "object",
      "required": ["passed", "violations"],
      "description": "美感與品牌一致性審查 — 任一違規 = fail",
      "properties": {
        "passed": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/violation" }
        },
        "checklist": {
          "$ref": "#/$defs/visual_checklist",
          "description": "Yes/No 快速檢查清單"
        }
      }
    },

    "guardrail_layer": {
      "type": "object",
      "required": ["notes"],
      "description": "護欄層 — 偏離記錄但不阻擋",
      "properties": {
        "notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/guardrail_note" }
        }
      }
    },

    "summary": {
      "type": "string",
      "description": "簡短審查摘要（1-3 句）"
    },

    "auto_fixable": {
      "type": "array",
      "items": { "type": "string" }
    },

    "needs_human": {
      "type": "array",
      "items": { "type": "string" }
    }
  },

  "$defs": {
    "violation": {
      "type": "object",
      "required": ["code", "severity", "message", "fix_hint"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "SCHEMA_INCOMPLETE",
            "SUBTITLE_NOT_ZHTW",
            "PROMPT_NOT_ZHCN",
            "SUBTITLE_TOO_LONG",
            "SUBTITLE_TOO_SHORT",
            "MISSING_BRAND_CLOSING",
            "MISSING_DATA_SOURCE",
            "MEDICAL_CLAIM",
            "DURATION_OUT_OF_RANGE",
            "HOOK_VARIANTS_INSUFFICIENT",
            "SCENE_IMAGE_MISSING_PROHIBITION",
            "TYPE_RATIONALE_MISSING",
            "MISSING_CORE_CLAIM",
            "MISSING_SINGLE_TAKEAWAY",

            "MULTIPLE_MAIN_MESSAGES",
            "VISUAL_NOT_SUPPORTING_MESSAGE",
            "TOO_MANY_OBJECTS",
            "TEXT_HARD_TO_SCAN",
            "CHEAP_SOCIAL_POSTER_STYLE",
            "HEADLINE_NOT_DOMINANT",
            "NO_CLEAR_HERO_OBJECT",

            "MASCOT_OVERUSED",
            "DUPLICATE_MASCOT",
            "DUPLICATE_3D_MASCOT",
            "MASCOT_STICKER_LIKE",
            "MASCOT_IDENTITY_DRIFT",
            "MASCOT_MATERIAL_DRIFT",
            "MASCOT_SCALE_TOO_LARGE",
            "MASCOT_NOT_SUPPORTING_MAIN_MESSAGE",
            "EMOTION_MISMATCH_WITH_HEADLINE",
            "HERO_OBJECT_NOT_DOMINANT",
            "PHOTO_3D_INTEGRATION_POOR",
            "PHOTO_VECTOR_NOT_INTEGRATED",
            "OLDER_AUDIENCE_UNFRIENDLY"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning"]
        },
        "message": { "type": "string" },
        "field_path": { "type": "string" },
        "fix_hint": { "type": "string" },
        "auto_fixable": {
          "type": "boolean",
          "default": false
        }
      }
    },

    "visual_checklist": {
      "type": "object",
      "description": "Yes/No 快速審查問題",
      "properties": {
        "single_main_message": { "type": "boolean", "description": "這張圖是否只有一個主訊息？" },
        "visual_supports_message": { "type": "boolean", "description": "視覺是否支援該主訊息？" },
        "headline_readable_1s": { "type": "boolean", "description": "觀眾 1 秒內能否讀到主標？" },
        "understandable_3s": { "type": "boolean", "description": "觀眾 3 秒內能否理解在講什麼？" },
        "mascot_single": { "type": "boolean", "description": "是否只有一隻小靜？" },
        "mascot_no_badge": { "type": "boolean", "description": "小靜是否沒有被用作 badge/貼紙？" },
        "mascot_emotion_correct": { "type": "boolean", "description": "表情是否正確服務標題？" },
        "text_large_enough": { "type": "boolean", "description": "字是否夠大（高齡友善）？" },
        "not_too_busy": { "type": "boolean", "description": "畫面是否不過滿？" },
        "no_excess_noise": { "type": "boolean", "description": "是否避免過度雜訊？" }
      }
    },

    "guardrail_note": {
      "type": "object",
      "required": ["aspect", "observation"],
      "properties": {
        "aspect": {
          "type": "string",
          "enum": [
            "hook_framework",
            "numeric_contrast",
            "framing_tone",
            "reveal_order",
            "camera_style",
            "color_palette",
            "layout_balance",
            "mascot_placement",
            "hero_object_choice"
          ]
        },
        "observation": { "type": "string" },
        "suggestion": { "type": "string" }
      }
    }
  }
}
