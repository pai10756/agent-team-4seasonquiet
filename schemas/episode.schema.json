{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "episode.schema.json",
  "title": "時時靜好 Episode JSON v3",
  "description": "scriptwriter 輸出、reviewer 驗證、asset_gen / assembler 消費的主契約。v3 加入 3D 吉祥物、視覺導演稿、場景角色定義。",
  "type": "object",

  "required": [
    "series", "episode", "type", "topic_title",
    "type_rationale",
    "core_claim", "single_takeaway",
    "visual_style_token",
    "hook_text", "hook_variants",
    "research_sources",
    "mascot_strategy",
    "scenes",
    "subtitles", "sound", "music",
    "youtube_metadata"
  ],

  "properties": {
    "series": {
      "type": "string",
      "description": "系列名稱",
      "examples": ["長輩廚房｜吃對了嗎？"]
    },
    "sub_series": {
      "type": "string",
      "description": "子系列名稱（ranking 型態時使用）"
    },
    "episode": {
      "type": "integer",
      "minimum": 1,
      "description": "集數"
    },
    "topic_id": {
      "type": "integer",
      "description": "對應 night-thinking 選題庫的 topic ID"
    },
    "topic_title": {
      "type": "string",
      "minLength": 1,
      "description": "主題標題"
    },
    "type": {
      "type": "string",
      "enum": ["standard", "ranking", "hybrid", "quick_cut"],
      "description": "影片型態"
    },
    "type_rationale": {
      "type": "string",
      "minLength": 10,
      "description": "選擇此型態的理由"
    },

    "core_claim": {
      "type": "string",
      "minLength": 10,
      "description": "這支片真正要講的唯一核心。例：「真正更該注意的是整體搭配中的飽和脂肪，不是只把雞蛋當成罪魁禍首。」"
    },
    "single_takeaway": {
      "type": "string",
      "minLength": 5,
      "description": "觀眾離開前只要記住這一句。例：「吃對搭配，比怕蛋更重要。」"
    },
    "audience_promise": {
      "type": "string",
      "description": "這支片對觀眾的承諾，例：「看完你會知道蛋到底能不能每天吃」"
    },

    "visual_style_token": {
      "type": "string",
      "const": "STYLE_SHIZHI_3D_POSTER_V1",
      "description": "視覺風格 token，對應 brand_visual_tokens.json"
    },

    "hook_text": {
      "type": "string",
      "minLength": 6,
      "description": "主 hook（繁體中文，6-10 字為佳）"
    },
    "hook_variants": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/hook_variant" }
    },

    "research_sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/research_source" }
    },

    "mascot_strategy": {
      "$ref": "#/$defs/mascot_strategy",
      "description": "3D 吉祥物小靜在本集的使用策略"
    },

    "scenes": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/scene_card" },
      "description": "導演稿場景卡列表 — 每張卡有明確角色和視覺規格"
    },

    "ranking_data": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/ranking_item" },
      "description": "排行榜數據（ranking/hybrid 型態必填）"
    },
    "comparison_note": {
      "type": "string",
      "description": "排行榜比較基準說明"
    },

    "character": {
      "type": "string",
      "description": "角色描述（standard/hybrid 型態必填）"
    },

    "seedance_prompts": {
      "type": "object",
      "properties": {
        "seedance_part1": { "type": "string" },
        "seedance_part2": { "type": "string" }
      },
      "description": "Seedance 影片生成 prompt（standard/hybrid 型態）"
    },

    "voiceover": {
      "$ref": "#/$defs/voiceover",
      "description": "TTS 配音設定"
    },

    "sound": { "type": "string", "description": "環境音描述" },
    "music": { "type": "string", "description": "配樂描述" },

    "subtitles": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/subtitle" }
    },

    "youtube_metadata": {
      "$ref": "#/$defs/youtube_metadata"
    },

    "scene_images": {
      "type": "array",
      "items": { "$ref": "#/$defs/scene_image_legacy" },
      "description": "Legacy: 向下相容的場景圖定義"
    },
    "global_spec": {
      "type": "string",
      "description": "Legacy: 全域視覺規格"
    },
    "format": { "type": "string" },
    "format_name": { "type": "string" },
    "parts": { "type": "array", "description": "Legacy: 影片分段" },
    "mascot": { "type": "object", "description": "Legacy: 舊版 mascot 欄位" }
  },

  "allOf": [
    {
      "if": { "properties": { "type": { "const": "standard" } } },
      "then": { "required": ["character", "seedance_prompts"] }
    },
    {
      "if": { "properties": { "type": { "const": "ranking" } } },
      "then": { "required": ["ranking_data", "comparison_note"] }
    },
    {
      "if": { "properties": { "type": { "const": "hybrid" } } },
      "then": { "required": ["character", "ranking_data", "seedance_prompts"] }
    }
  ],

  "$defs": {
    "hook_variant": {
      "type": "object",
      "required": ["level", "text"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["unaware", "problem_aware", "solution_aware", "audience"]
        },
        "text": { "type": "string", "minLength": 6 },
        "rationale": { "type": "string" }
      }
    },

    "research_source": {
      "type": "object",
      "required": ["citation", "key_finding"],
      "properties": {
        "citation": { "type": "string" },
        "url": { "type": "string", "pattern": "^https?://" },
        "key_finding": { "type": "string" }
      }
    },

    "mascot_strategy": {
      "type": "object",
      "required": ["presence"],
      "properties": {
        "presence": {
          "type": "string",
          "enum": ["opening_only", "closing_only", "both", "none"],
          "description": "小靜在哪些卡出現"
        },
        "opening_expression": {
          "$ref": "#/$defs/mascot_expression",
          "description": "開場卡的表情"
        },
        "opening_pose": {
          "type": "string",
          "enum": ["hug_object_side", "lean_on_object", "think_with_object", "hold_badge", "point_up"],
          "description": "開場卡的姿勢"
        },
        "closing_expression": {
          "type": "string",
          "const": "goodbye"
        },
        "allow_middle_cards": {
          "type": "boolean",
          "default": false,
          "description": "中間卡是否允許出現小靜（預設不允許）"
        },
        "outfit": {
          "type": "string",
          "enum": ["apron", "none", "sport_vest", "sleep_cap", "doctor_coat"],
          "default": "apron"
        },
        "prop": {
          "type": "string",
          "description": "手持小道具（icon 級別），如 'tiny egg'"
        },
        "render_mode": {
          "type": "string",
          "const": "3d_exact_reference",
          "description": "必須使用 3D reference image 生成"
        },
        "scale_vs_object": {
          "type": "string",
          "enum": ["small", "equal", "large"],
          "default": "small",
          "description": "相對 hero object 的大小：small=配角, equal=同等, large=主角"
        },
        "allow_extra_mascot": {
          "type": "boolean",
          "default": false
        },
        "allow_logo_mascot": {
          "type": "boolean",
          "default": false
        }
      }
    },

    "mascot_expression": {
      "type": "string",
      "enum": ["default", "surprised", "thinking", "happy", "reminder", "goodbye", "worried", "proud"]
    },

    "scene_card": {
      "type": "object",
      "required": ["scene_id", "scene_role", "scene_goal", "visual_type"],
      "properties": {
        "scene_id": {
          "type": "string",
          "pattern": "^[0-9]{2}$",
          "description": "兩位數場景編號，如 '01', '02'"
        },
        "scene_role": {
          "type": "string",
          "enum": ["hook", "flip", "compare", "evidence", "reminder", "closing"],
          "description": "這張卡的敘事角色"
        },
        "scene_goal": {
          "type": "string",
          "description": "這張卡要達成的觀眾反應"
        },
        "on_screen_text_main": {
          "type": "string",
          "description": "主標題文字（繁體中文），將在合成階段疊加"
        },
        "on_screen_text_sub": {
          "type": "string",
          "description": "副標題文字"
        },
        "visual_type": {
          "type": "string",
          "enum": ["poster_cover", "comparison_card", "evidence_card", "safety_reminder", "brand_closing"],
          "description": "視覺版型，對應 brand_visual_tokens.json 的 card_types"
        },
        "hero_object": {
          "type": "string",
          "description": "主視覺物件描述（英文），如 'one large realistic white egg on wooden table'"
        },
        "hero_object_priority": {
          "type": "string",
          "enum": ["primary", "secondary"],
          "default": "primary"
        },
        "photo_realism_ratio": {
          "type": "number",
          "minimum": 0, "maximum": 1,
          "default": 0.75,
          "description": "寫實底圖佔比"
        },
        "background_scene": {
          "type": "string",
          "description": "背景場景描述（英文），如 'warm kitchen interior, soft natural light'"
        },
        "mascot_presence": {
          "type": "boolean",
          "default": false,
          "description": "此卡是否有小靜"
        },
        "mascot_count": {
          "type": "integer",
          "maximum": 1,
          "default": 0
        },
        "mascot_expression": { "$ref": "#/$defs/mascot_expression" },
        "mascot_pose": {
          "type": "string",
          "enum": ["hug_object_side", "lean_on_object", "greet_viewer", "think_with_object", "hold_badge", "point_up"]
        },
        "mascot_interaction_mode": {
          "type": "string",
          "description": "小靜與 hero object 的互動方式"
        },
        "badge_text": {
          "type": "string",
          "description": "右上角 badge 文字，如 '2025\\n研究更新'"
        },
        "source_badge_text": {
          "type": "string",
          "description": "資料來源 badge 文字"
        },
        "do_not_include": {
          "type": "array",
          "items": { "type": "string" },
          "description": "此卡明確禁止的視覺元素"
        },
        "time_range": {
          "type": "string",
          "description": "在影片中的時間範圍，如 '0-3s'"
        },
        "animation": {
          "type": "string",
          "enum": ["slow_push_in", "slight_drift", "simple_cut", "slide_in", "badge_fade_in", "mascot_wave", "none"],
          "description": "此卡的動畫效果"
        }
      }
    },

    "ranking_item": {
      "type": "object",
      "required": ["rank", "food", "value", "unit", "comparison"],
      "properties": {
        "rank": { "type": "integer", "minimum": 1 },
        "food": { "type": "string" },
        "food_en": { "type": "string" },
        "value": { "type": ["number", "string"] },
        "unit": { "type": "string" },
        "serving_note": { "type": "string" },
        "comparison": { "type": "string" },
        "food_image": { "type": "string" }
      }
    },

    "voiceover": {
      "type": "object",
      "required": ["engine", "segments"],
      "properties": {
        "engine": { "type": "string", "enum": ["elevenlabs"] },
        "model": { "type": "string" },
        "voice_settings": {
          "type": "object",
          "properties": {
            "stability": { "type": "number" },
            "similarity_boost": { "type": "number" },
            "style": { "type": "number" },
            "speed": { "type": "number" }
          }
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "part", "text"],
            "properties": {
              "id": { "type": "integer" },
              "part": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        }
      }
    },

    "subtitle": {
      "type": "object",
      "required": ["text", "start", "end"],
      "properties": {
        "text": { "type": "string", "minLength": 2, "maxLength": 15 },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "style": {
          "type": "string",
          "enum": ["main", "ranking", "data", "ranking_champion", "comparison"]
        }
      }
    },

    "youtube_metadata": {
      "type": "object",
      "required": ["title", "description", "hashtags"],
      "properties": {
        "title": { "type": "string", "maxLength": 100 },
        "description": { "type": "string" },
        "hashtags": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "pattern": "^#" }
        }
      }
    },

    "scene_image_legacy": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "part": {},
        "description": { "type": "string" },
        "prompt": { "type": "string" }
      }
    }
  }
}
