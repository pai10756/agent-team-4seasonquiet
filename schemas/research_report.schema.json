{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "research_report.schema.json",
  "title": "Research Report",
  "description": "researcher 輸出給 scriptwriter 的研究報告契約。",
  "type": "object",

  "required": [
    "topic", "topic_id",
    "cognitive_gap", "verified_data",
    "sources", "recommended_type",
    "engagement_signals"
  ],

  "properties": {
    "topic": {
      "type": "string",
      "description": "研究主題"
    },
    "topic_id": {
      "type": "integer",
      "description": "night-thinking 選題庫 ID"
    },

    "cognitive_gap": {
      "type": "object",
      "required": ["common_belief", "actual_finding", "contrast_magnitude"],
      "description": "認知反差點 — scriptwriter 用來設計 hook",
      "properties": {
        "common_belief": {
          "type": "string",
          "description": "大眾普遍認知（要被顛覆的）"
        },
        "actual_finding": {
          "type": "string",
          "description": "研究實際發現"
        },
        "contrast_magnitude": {
          "type": "string",
          "description": "反差程度描述（如 '12倍差距'、'完全相反'）"
        }
      }
    },

    "verified_data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "source_citation", "confidence"],
        "properties": {
          "claim": {
            "type": "string",
            "description": "可引用的數據聲明"
          },
          "source_citation": {
            "type": "string",
            "description": "來源引用（期刊+年份 或 機構）"
          },
          "source_url": {
            "type": "string",
            "pattern": "^https?://"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "數據可信度: high=RCT/系統回顧, medium=觀察性研究, low=單一小型研究"
          }
        }
      },
      "description": "已查證的數據點"
    },

    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["citation", "key_finding"],
        "properties": {
          "citation": { "type": "string" },
          "url": { "type": "string", "pattern": "^https?://" },
          "key_finding": { "type": "string" },
          "study_type": {
            "type": "string",
            "enum": ["rct", "meta_analysis", "cohort", "cross_sectional", "review", "guideline", "database"],
            "description": "研究類型"
          }
        }
      }
    },

    "recommended_type": {
      "type": "string",
      "enum": ["standard", "ranking", "hybrid", "quick_cut"],
      "description": "建議的影片型態"
    },
    "type_reasoning": {
      "type": "string",
      "description": "為什麼建議此型態"
    },

    "engagement_signals": {
      "type": "object",
      "required": ["virality_score"],
      "properties": {
        "virality_score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "爆量潛力評分 1-10"
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" },
          "description": "爆量理由"
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "潛在風險（如爭議性、合規問題）"
        }
      }
    },

    "ranking_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "value", "unit", "source"],
        "properties": {
          "item": { "type": "string" },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "source": { "type": "string" }
        }
      },
      "description": "如果建議 ranking 型態，提供排行候選數據"
    },

    "misbelief_to_correct": {
      "type": "string",
      "description": "要破除的迷思（一句話），例：「一天只能吃一顆蛋」"
    },
    "safe_claim": {
      "type": "string",
      "description": "安全的結論聲明（不過度簡化），例：「近年研究支持，影響 LDL 的因素更接近整體飲食中的飽和脂肪」"
    },
    "unsafe_claims_to_avoid": {
      "type": "array",
      "items": { "type": "string" },
      "description": "絕對不能出現的說法，例：「膽固醇完全不用管」"
    },

    "good_cover_objects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "適合作為封面 hero object 的物件（scriptwriter/asset_gen 用），例：[\"白殼雞蛋\", \"水煮蛋\", \"木桌早餐場景\"]"
    },
    "comparison_objects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "適合做比較卡的物件組，例：[\"蛋 vs 培根\", \"水煮蛋 vs 荷包蛋\"]"
    },
    "visualizable_objects": {
      "type": "array",
      "items": { "type": "string" },
      "description": "可以視覺化的物件清單（所有可用的 hero object 候選）"
    },
    "mascot_recommended_pose": {
      "type": "string",
      "enum": ["hug_object_side", "lean_on_object", "think_with_object", "hold_badge", "point_up"],
      "description": "建議的小靜封面姿勢"
    },
    "visual_risk_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "視覺設計需注意的風險，例：[\"不能讓蛋看起來像壞掉的\", \"避免醫療恐嚇風格\"]"
    },
    "audience_sensitivity_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "受眾敏感度提醒，例：[\"高膽固醇血症患者需醫囑提醒\"]"
    }
  }
}
